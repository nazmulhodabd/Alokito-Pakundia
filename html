<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>সহায়তা ফাউন্ডেশন | Together we can change lives</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="navbar">
        <div class="logo">SAHAYATA.</div>
        <ul class="nav-links">
            <li><a href="#home">হোম</a></li>
            <li><a href="#about">আমাদের সম্পর্কে</a></li>
            <li><a href="#projects">প্রজেক্টসমূহ</a></li>
            <li><a href="#gallery">গ্যালারি</a></li>
            <li><a href="#contact">যোগাযোগ</a></li>
            <li><a href="#donate" class="nav-btn">ডোনেট করুন</a></li>
        </ul>
    </nav>

    <header id="home" class="hero">
        <div class="hero-content">
            <h1>“Together we can <br><span class="highlight">change lives</span>”</h1>
            <p>আমাদের ক্ষুদ্র প্রচেষ্টা বদলে দিতে পারে কারো জীবন। আজই আমাদের সাথে যুক্ত হোন।</p>
            <div class="hero-btns">
                <a href="#projects" class="btn-main">আমাদের কাজ</a>
                <a href="#volunteer" class="btn-sub">ভলান্টিয়ার হন</a>
            </div>
        </div>
    </header>

    <section id="about" class="section">
        <div class="container">
            <h2 class="section-title">আমরা কি করি</h2>
            <div class="about-grid">
                <div class="about-text">
                    <h3>আমাদের লক্ষ্য ও পরিকল্পনা</h3>
                    <p>সমাজের সুবিধাবঞ্চিত মানুষের পাশে দাঁড়ানোই আমাদের মূল লক্ষ্য। আমরা বিশ্বাস করি শিক্ষার আলো এবং সঠিক চিকিৎসা প্রতিটি মানুষের অধিকার। ভবিষ্যতে আমরা একটি স্থায়ী আশ্রয়কেন্দ্র এবং ফ্রি স্কুল গড়ার পরিকল্পনা করছি।</p>
                </div>
            </div>
        </div>
    </section>

    <section id="projects" class="section bg-light">
        <div class="container">
            <h2 class="section-title">আমাদের প্রজেক্টসমূহ</h2>
            <div class="project-grid">
                <div class="card">
                    <div class="img-placeholder">খাদ্য বিতরণ</div>
                    <h3>Food Distribution</h3>
                    <p>৫০০+ পরিবারকে মাসিক খাদ্য সহায়তা প্রদান।</p>
                </div>
                <div class="card">
                    <div class="img-placeholder">শিক্ষা সহায়তা</div>
                    <h3>Education</h3>
                    <p>গরীব শিক্ষার্থীদের স্কুল ফি ও বই প্রদান।</p>
                </div>
                <div class="card">
                    <div class="img-placeholder">চিকিৎসা সেবা</div>
                    <h3>Medical Help</h3>
                    <p>ফ্রি মেডিকেল ক্যাম্প ও ঔষধ বিতরণ।</p>
                </div>
            </div>
        </div>
    </section>

    <section id="donate" class="section">
        <div class="container donate-box">
            <h2>সহযোগিতার হাত বাড়িয়ে দিন</h2>
            <p>আপনার পাঠানো অনুদান সরাসরি মানুষের কল্যাণে ব্যয় করা হয়।</p>
            <div class="payment-methods">
                <span>bkash: 01XXX-XXXXXX</span>
                <span>Nagad: 01XXX-XXXXXX</span>
                <span>Bank: Trust Bank Ltd.</span>
            </div>
        </div>
    </section>

    <section id="volunteer" class="section bg-light">
        <div class="container">
            <h2 class="section-title">ভলান্টিয়ার হিসেবে যোগ দিন</h2>
            <form class="v-form">
                <input type="text" placeholder="আপনার নাম" required>
                <input type="email" placeholder="আপনার ইমেইল" required>
                <input type="text" placeholder="ফোন নম্বর" required>
                <textarea placeholder="আপনার দক্ষতা (যেমন: গ্রাফিক ডিজাইন, ইভেন্ট ম্যানেজমেন্ট)" rows="4"></textarea>
                <button type="submit" class="btn-main">আবেদন করুন</button>
            </form>
        </div>
    </section>

    <footer class="footer">
        <div class="container">
            <p>&copy; ২০২৬ সহায়তা ফাউন্ডেশন। সকল অধিকার সংরক্ষিত।</p>
            <p>ঠিকানা: ঢাকা, বাংলাদেশ | ইমেইল: info@help.org</p>
        </div>
    </footer>

</body>
</html>
